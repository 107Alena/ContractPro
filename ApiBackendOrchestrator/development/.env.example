# =============================================================================
# ContractPro Orchestrator — Environment Variables (.env.example)
# =============================================================================
# Copy to .env and adjust values as needed:
#   cp .env.example .env
#
# Variables marked [COMPOSE OVERRIDE] are set in docker-compose.yaml and
# do not need to be changed here for local Docker development.
# They are listed for reference and for running the binary outside Docker.
#
# Full reference: ../architecture/configuration.md
# =============================================================================

# --- Message Broker (RabbitMQ) [COMPOSE OVERRIDE] ---
ORCH_BROKER_ADDRESS=amqp://guest:guest@localhost:5672/

# --- Redis [COMPOSE OVERRIDE] ---
ORCH_REDIS_ADDRESS=localhost:6379
# ORCH_REDIS_PASSWORD=
# ORCH_REDIS_DB=0
# ORCH_REDIS_POOL_SIZE=20

# --- Object Storage (MinIO for dev) [COMPOSE OVERRIDE] ---
ORCH_STORAGE_ENDPOINT=http://localhost:9000
ORCH_STORAGE_BUCKET=contractpro-uploads
ORCH_STORAGE_ACCESS_KEY=minioadmin
ORCH_STORAGE_SECRET_KEY=minioadmin
# ORCH_STORAGE_REGION=ru-central1

# --- Document Management Service (sync REST) ---
# DM runs outside this compose stack. Use host.docker.internal from inside
# Docker, or localhost when running the binary directly.
ORCH_DM_BASE_URL=http://host.docker.internal:8081
# ORCH_DM_TIMEOUT_READ=5s
# ORCH_DM_TIMEOUT_WRITE=10s

# --- JWT Authentication ---
# Path inside the container; keys/ is mounted as a read-only volume.
ORCH_JWT_PUBLIC_KEY_PATH=/keys/jwt-public.pem

# --- HTTP Server ---
# ORCH_HTTP_PORT=8080
# ORCH_METRICS_PORT=9090
# ORCH_REQUEST_TIMEOUT=30s
# ORCH_UPLOAD_TIMEOUT=60s
# ORCH_SHUTDOWN_TIMEOUT=30s

# --- Logging ---
ORCH_LOG_LEVEL=debug

# --- Rate Limiting (disabled for dev) ---
ORCH_RATELIMIT_ENABLED=false

# --- CORS (allow local frontend dev servers) ---
ORCH_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- SSE ---
# ORCH_SSE_HEARTBEAT_INTERVAL=15s
# ORCH_SSE_MAX_CONNECTION_AGE=24h

# --- Upload ---
# ORCH_UPLOAD_MAX_SIZE=20971520
# ORCH_UPLOAD_ALLOWED_TYPES=application/pdf
# ORCH_UPLOAD_MAX_CONCURRENT=10

# --- OPM Service (optional, disabled by default for dev) ---
# ORCH_OPM_BASE_URL=http://host.docker.internal:8082

# --- UOM Service (optional, disabled by default for dev) ---
# ORCH_UOM_BASE_URL=http://host.docker.internal:8083

# --- Circuit Breaker ---
# ORCH_CB_FAILURE_THRESHOLD=5
# ORCH_CB_TIMEOUT=30s
# ORCH_CB_MAX_REQUESTS=3

# --- Tracing (disabled for dev) ---
# ORCH_TRACING_ENABLED=false
# ORCH_TRACING_ENDPOINT=
