# ContractPro Frontend — Docker build context exclusions.
# Держим контекст минимальным: build запускает npm ci от нуля внутри контейнера.

# Node / Vite build output
node_modules
dist
dist-ssr
.vite

# Тестовые артефакты и отчёты
coverage
storybook-static
playwright-report
test-results

# VCS и CI
.git
.github

# IDE / OS
.vscode
.idea
.DS_Store
*.swp

# Локальные env-файлы (build-time VITE_* приходят через ARG, не из .env).
# .env.e2e — e2e-mode (FE-TASK-055), исключён из runtime-образа.
.env
.env.local
.env.*.local
.env.e2e
.env.e2e.local

# Playwright конфиг — не нужен внутри прод-образа
playwright.config.ts

# Документация / tasks — не нужны для сборки runtime-образа
progress.md
tasks.json
backlog-tasks.json
architecture
tests/e2e

# Логи
npm-debug.log*
yarn-debug.log*
*.log
