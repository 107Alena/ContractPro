# =============================================================================
# ContractPro — Document Processing Worker Configuration
# =============================================================================
# Copy this file to .env and fill in the required values.
# Already-set environment variables take precedence over .env values.
# See: DocumentProcessing/architecture/configuration.md
# =============================================================================

# -----------------------------------------------------------------------------
# Message Broker (RabbitMQ) — REQUIRED
# -----------------------------------------------------------------------------
DP_BROKER_ADDRESS=amqp://user:password@localhost:5672/

# Broker topic overrides (defaults shown — override only if needed)
# DP_BROKER_TOPIC_PROCESS_DOCUMENT=dp.commands.process-document
# DP_BROKER_TOPIC_COMPARE_VERSIONS=dp.commands.compare-versions
# DP_BROKER_TOPIC_ARTIFACTS_READY=dp.artifacts.processing-ready
# DP_BROKER_TOPIC_SEMANTIC_TREE_REQUEST=dp.requests.semantic-tree
# DP_BROKER_TOPIC_DIFF_READY=dp.artifacts.diff-ready
# DP_BROKER_TOPIC_DM_ARTIFACTS_PERSISTED=dm.responses.artifacts-persisted
# DP_BROKER_TOPIC_DM_ARTIFACTS_PERSIST_FAILED=dm.responses.artifacts-persist-failed
# DP_BROKER_TOPIC_DM_SEMANTIC_TREE_PROVIDED=dm.responses.semantic-tree-provided
# DP_BROKER_TOPIC_DM_DIFF_PERSISTED=dm.responses.diff-persisted
# DP_BROKER_TOPIC_DM_DIFF_PERSIST_FAILED=dm.responses.diff-persist-failed
# DP_BROKER_TOPIC_STATUS_CHANGED=dp.events.status-changed
# DP_BROKER_TOPIC_PROCESSING_COMPLETED=dp.events.processing-completed
# DP_BROKER_TOPIC_PROCESSING_FAILED=dp.events.processing-failed
# DP_BROKER_TOPIC_COMPARISON_COMPLETED=dp.events.comparison-completed
# DP_BROKER_TOPIC_COMPARISON_FAILED=dp.events.comparison-failed

# -----------------------------------------------------------------------------
# Yandex Object Storage (S3-compatible) — REQUIRED
# -----------------------------------------------------------------------------
DP_STORAGE_ENDPOINT=https://storage.yandexcloud.net
DP_STORAGE_BUCKET=dp-artifacts
DP_STORAGE_ACCESS_KEY=your-access-key-here
DP_STORAGE_SECRET_KEY=your-secret-key-here
# DP_STORAGE_REGION=ru-central1

# -----------------------------------------------------------------------------
# Yandex Cloud Vision OCR — REQUIRED
# -----------------------------------------------------------------------------
DP_OCR_ENDPOINT=https://ocr.api.cloud.yandex.net
DP_OCR_API_KEY=your-ocr-api-key-here
DP_OCR_FOLDER_ID=your-folder-id-here
# DP_OCR_RPS_LIMIT=10

# -----------------------------------------------------------------------------
# Redis KV Store (idempotency, state) — REQUIRED
# -----------------------------------------------------------------------------
DP_KVSTORE_ADDRESS=localhost:6379
# DP_KVSTORE_PASSWORD=
# DP_KVSTORE_DB=0
# DP_KVSTORE_POOL_SIZE=10
# DP_KVSTORE_TIMEOUT=5s

# -----------------------------------------------------------------------------
# HTTP Server (health/readiness probes)
# -----------------------------------------------------------------------------
# DP_HTTP_PORT=8080

# -----------------------------------------------------------------------------
# Processing Limits
# -----------------------------------------------------------------------------
# DP_LIMITS_MAX_FILE_SIZE=20971520
# DP_LIMITS_MAX_PAGES=100
# DP_LIMITS_JOB_TIMEOUT=120s

# -----------------------------------------------------------------------------
# Concurrency
# -----------------------------------------------------------------------------
# DP_CONCURRENCY_MAX_JOBS=5

# -----------------------------------------------------------------------------
# Idempotency Guard
# -----------------------------------------------------------------------------
# DP_IDEMPOTENCY_TTL=24h

# -----------------------------------------------------------------------------
# Retry Policy
# -----------------------------------------------------------------------------
# DP_RETRY_MAX_ATTEMPTS=3
# DP_RETRY_BACKOFF_BASE=1s

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
# DP_LOG_LEVEL=info
# DP_METRICS_PORT=9090
# DP_TRACING_ENABLED=false
# DP_TRACING_ENDPOINT=
# DP_TRACING_INSECURE=false
