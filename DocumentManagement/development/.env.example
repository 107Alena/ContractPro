# =============================================================================
# ContractPro — Document Management Service Configuration
# =============================================================================
# Copy this file to .env and fill in the required values.
# Already-set environment variables take precedence over .env values.
#
# When running with docker-compose, most required values are provided via
# the environment block in docker-compose.yaml. This .env file is still
# loaded but the compose overrides take precedence.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL Database — REQUIRED
# -----------------------------------------------------------------------------
DM_DB_DSN=postgres://dm:dm_dev_password@localhost:5433/dm_dev?sslmode=disable
# DM_DB_MAX_CONNS=25
# DM_DB_MIN_CONNS=5
# DM_DB_QUERY_TIMEOUT=10s

# -----------------------------------------------------------------------------
# Message Broker (RabbitMQ) — REQUIRED
# -----------------------------------------------------------------------------
DM_BROKER_ADDRESS=amqp://guest:guest@localhost:5673/
# DM_BROKER_TLS=false

# Broker topic overrides (all have sensible defaults from model.Topic* constants).
# Override only if your environment uses non-standard topic names.
# See internal/config/sub_configs.go for the full list of DM_BROKER_TOPIC_* vars.

# -----------------------------------------------------------------------------
# Object Storage (S3-compatible) — REQUIRED
# For local dev: MinIO at localhost:9000
# For production: Yandex Object Storage
# -----------------------------------------------------------------------------
DM_STORAGE_ENDPOINT=http://localhost:9000
DM_STORAGE_BUCKET=dm-artifacts
DM_STORAGE_ACCESS_KEY=minioadmin
DM_STORAGE_SECRET_KEY=minioadmin
# DM_STORAGE_REGION=ru-central1  # docker-compose overrides to us-east-1 for MinIO
# DM_STORAGE_PRESIGNED_TTL=5m

# -----------------------------------------------------------------------------
# Redis KV Store (idempotency) — REQUIRED
# -----------------------------------------------------------------------------
DM_KVSTORE_ADDRESS=localhost:6380
# DM_KVSTORE_PASSWORD=
# DM_KVSTORE_DB=0
# DM_KVSTORE_POOL_SIZE=10
# DM_KVSTORE_TIMEOUT=2s

# -----------------------------------------------------------------------------
# HTTP Server
# -----------------------------------------------------------------------------
# DM_HTTP_PORT=8080

# -----------------------------------------------------------------------------
# Consumer Settings
# -----------------------------------------------------------------------------
# DM_CONSUMER_PREFETCH=10
# DM_CONSUMER_CONCURRENCY=5

# -----------------------------------------------------------------------------
# Idempotency Guard
# -----------------------------------------------------------------------------
# DM_IDEMPOTENCY_TTL=24h
# DM_IDEMPOTENCY_PROCESSING_TTL=120s
# DM_IDEMPOTENCY_STUCK_THRESHOLD=240s

# -----------------------------------------------------------------------------
# Transactional Outbox
# -----------------------------------------------------------------------------
# DM_OUTBOX_POLL_INTERVAL=200ms
# DM_OUTBOX_BATCH_SIZE=50
# DM_OUTBOX_LOCK_TIMEOUT=5s
# DM_OUTBOX_CLEANUP_HOURS=48

# -----------------------------------------------------------------------------
# Retry Policy
# -----------------------------------------------------------------------------
# DM_RETRY_MAX_ATTEMPTS=3
# DM_RETRY_BACKOFF_BASE=1s

# -----------------------------------------------------------------------------
# Dead Letter Queue
# -----------------------------------------------------------------------------
# DM_DLQ_MAX_REPLAY_COUNT=3

# -----------------------------------------------------------------------------
# Data Retention
# -----------------------------------------------------------------------------
# DM_RETENTION_ARCHIVE_DAYS=90
# DM_RETENTION_DELETED_BLOB_DAYS=30
# DM_RETENTION_DELETED_META_DAYS=365
# DM_RETENTION_AUDIT_DAYS=1095

# -----------------------------------------------------------------------------
# Timeouts
# -----------------------------------------------------------------------------
# DM_TIMEOUT_STORAGE_PUT=30s
# DM_TIMEOUT_STORAGE_GET=15s
# DM_TIMEOUT_EVENT_PROCESSING=60s
# DM_TIMEOUT_BROKER_PUBLISH=10s
# DM_STALE_VERSION_TIMEOUT=30m
# DM_SHUTDOWN_TIMEOUT=30s

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
# DM_LOG_LEVEL=info
# DM_METRICS_PORT=9090
# DM_TRACING_ENABLED=false
# DM_TRACING_ENDPOINT=
# DM_TRACING_INSECURE=false
