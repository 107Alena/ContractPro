{
  "uid": "cp-overview",
  "title": "ContractPro — Services Overview",
  "tags": ["contractpro", "overview"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "API Backend Orchestrator (HTTP RED)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request rate (req/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (route) (rate(orch_http_requests_total[1m]))",
          "legendFormat": "{{route}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Error rate (5xx, req/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (route) (rate(orch_http_requests_total{status=~\"5..\"}[1m]))",
          "legendFormat": "{{route}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99 (s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum by (le) (rate(orch_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p50" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le) (rate(orch_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p95" },
        { "refId": "C", "expr": "histogram_quantile(0.99, sum by (le) (rate(orch_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 10,
      "type": "row",
      "title": "Go runtime (Orchestrator)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Goroutines",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 10 },
      "targets": [
        { "refId": "A", "expr": "go_goroutines{job=\"orchestrator\"}", "legendFormat": "goroutines" }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Heap in-use (MB)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 10 },
      "targets": [
        { "refId": "A", "expr": "go_memstats_heap_inuse_bytes{job=\"orchestrator\"} / 1024 / 1024", "legendFormat": "heap" }
      ],
      "fieldConfig": { "defaults": { "unit": "decmbytes" }, "overrides": [] }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "GC pause p99 (s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 10 },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.99, rate(go_gc_duration_seconds_bucket{job=\"orchestrator\"}[5m]))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 20,
      "type": "row",
      "title": "Cross-service signals",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 }
    },
    {
      "id": 21,
      "type": "stat",
      "title": "Active SSE connections",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 18 },
      "targets": [
        { "refId": "A", "expr": "orch_sse_connections_active" }
      ]
    },
    {
      "id": 22,
      "type": "stat",
      "title": "DP concurrent jobs (active)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 18 },
      "targets": [
        { "refId": "A", "expr": "dp_concurrent_jobs_active" }
      ]
    },
    {
      "id": 23,
      "type": "stat",
      "title": "DM outbox pending",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 18 },
      "targets": [
        { "refId": "A", "expr": "dm_outbox_pending_count" }
      ]
    },
    {
      "id": 24,
      "type": "stat",
      "title": "DM oldest outbox age (s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 18 },
      "targets": [
        { "refId": "A", "expr": "dm_outbox_oldest_pending_age_seconds" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    }
  ]
}
